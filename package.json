{
  "name": "pd2-x64-converter",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.11.0",
  "repository": "https://github.com/perry519/pd2-x64-converter",
  "scripts": {
    "dev": "vite",
    "dev:tauri:webdriver": "VITE_TAURI_E2E=1 WDIO_EMBEDDED_SERVER=true TAURI_WEBDRIVER_PORT=4565 WEBKIT_DISABLE_DMABUF_RENDERER=1 node scripts/tauri.mjs dev --features e2e --config src-tauri/tauri.e2e.conf.json",
    "build": "vite build",
    "build:gui:linux": "pnpm run tauri build --no-bundle",
    "build:gui:linux:appimage": "bash scripts/build-appimage.sh",
    "build:cli:linux": "cargo build --release -p pd2-x64-converter-cli",
    "build:gui:windows": "pnpm run tauri build --no-bundle",
    "build:gui:windows:installer": "pnpm run tauri build --bundles nsis",
    "build:cli:windows": "cargo build --release -p pd2-x64-converter-cli",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "e2e:tauri:build": "node scripts/tauri.mjs build --debug --no-bundle --config src-tauri/tauri.e2e.conf.json --features e2e",
    "e2e:tauri": "pnpm run e2e:tauri:build && wdio run wdio.conf.mjs",
    "lint": "eslint . && node scripts/check-tailwind-canonical.mjs",
    "lint:fix": "eslint --fix . && node scripts/check-tailwind-canonical.mjs",
    "fallow:audit": "fallow audit --root \"$PWD\" --changed-since HEAD --format json",
    "fallow:health": "fallow health --root \"$PWD\"",
    "fallow:dead-code": "fallow dead-code --root \"$PWD\"",
    "fallow:dupes": "fallow dupes --root \"$PWD\" --mode mild",
    "rust:dupes": "cargo tree -d",
    "tauri:test": "cargo test -p pd2-x64-converter-tauri",
    "tauri": "node scripts/tauri.mjs"
  },
  "dependencies": {
    "@lucide/svelte": "^1.24.0",
    "@tanstack/svelte-virtual": "^3.13.31",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-store": "^2.4.3",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "svelte": "^5.56.4",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@internationalized/date": "^3.12.2",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.4.2",
    "@types/node": "^26.1.1",
    "@wdio/cli": "^9.29.1",
    "@wdio/globals": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/mocha-framework": "^9.29.1",
    "@wdio/spec-reporter": "^9.29.1",
    "eslint": "^10.7.0",
    "eslint-plugin-better-tailwindcss": "^4.6.1",
    "eslint-plugin-svelte": "^3.20.0",
    "fallow": "^3.3.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "svelte-check": "^4.7.2",
    "typescript": "~6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "webdriverio": "^9.29.1"
  }
}
